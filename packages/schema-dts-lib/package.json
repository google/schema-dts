{
  "name": "schema-dts-lib",
  "version": "1.0.0",
  "displayName": "schema-dts Library",
  "description": "Library for JSON-LD vocabularies",
  "author": "Eyas Sharaiha <eyas@google.com> (https://eyas.sh/)",
  "maintainers": [
    "Eyas Sharaiha <npm@eyas.sh> (https://eyas.sh/)"
  ],
  "contributors": [
    "Eyas Sharaiha <npm@eyas.sh> (https://eyas.sh/)"
  ],
  "files": [
    "dist/**/*"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "sideEffects": false,
  "type": "module",
  "devDependencies": {},
  "dependencies": {},
  "engines": {
    "node": ">=14.0.0"
  },
  "engineStrict": true,
